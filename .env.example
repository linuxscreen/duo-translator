VITE_ENV=dev
VITE_APP_NAME=your-app-name
VITE_GOOGLE_API_KEY=your-google-api-key
VITE_GOOGLE_CLIENT_ID=your-google-client-id
# TEMPORARY (debug only): secret of the "Web application" OAuth client. For the
# local / test-users stage only — switch to a backend token broker and remove
# this for production (see the note at the top of googleDriveProvider.ts).
VITE_GOOGLE_CLIENT_SECRET=your-google-client-secret
VITE_WEBSITE=https://localhost